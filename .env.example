# Postgres connection string.
# Local dev: defaults to the local Supabase stack if unset (see lib/db.ts).
# Production (Vercel): use the Supabase transaction pooler URL (port 6543), e.g.
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54342/postgres

# Secret for better-auth session/cookie signing. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Deployed origin, required in production, e.g. https://<project>.vercel.app
# Leave unset for local dev (inferred from the request).
BETTER_AUTH_URL=

# Gmail account used to send payment receipt emails to tenants.
# GMAIL_APP_PASSWORD is a Google App Password (requires 2FA on the account):
#   https://myaccount.google.com/apppasswords
# Leave unset to disable email sending (payments still record normally).
GMAIL_USER=8turfapt@gmail.com
GMAIL_APP_PASSWORD=

# Google Drive OAuth credentials for tenant document uploads (same Gmail
# account as GMAIL_USER, but the app password does not work for Drive).
# One-time setup: Google Cloud project → enable Drive API → OAuth consent
# screen (External, published to Production) → Web OAuth client with
# http://127.0.0.1:53682 as redirect URI. Then run: bun run get-drive-token
# Leave unset to disable tenant document uploads (everything else still works).
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Semaphore (semaphore.co) API key for SMS rent reminders to tenants with a
# phone number. Leave unset to disable SMS sending (email reminders still work).
SEMAPHORE_API_KEY=
# Optional pre-approved Semaphore sender name (e.g. 8TURF). Leave unset to use
# the Semaphore default sender name.
SEMAPHORE_SENDER_NAME=
